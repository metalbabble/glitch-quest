{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start App (npm start)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm start",
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "pattern": "https?://localhost:[0-9]+",
                "action": "startDebugging",
                "name": "Open in Firefox"
            }
        },
        {
            "name": "Open in Firefox",
            "type": "node-terminal",
            "request": "launch",
            "command": "firefox http://localhost:3000",
            "cwd": "${workspaceFolder}"
        }
    ]
}